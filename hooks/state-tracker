# PostToolUse hook for software-engineer-agents.
# Keeps .sea/state.json's last_edit timestamp fresh whenever Claude
# edits a file in a project that's already initialized with software-engineer-agents.

set -euo pipefail

ACTION="${1:-file-touched}"

STATE_DIR=".sea"
STATE_FILE="${STATE_DIR}/state.json"

# Only operate in initialized projects. In every other case, silently no-op.
[ -f "$STATE_FILE" ] || exit 0
command -v jq >/dev/null 2>&1 || exit 0

NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

case "$ACTION" in
    file-touched)
        TMP=$(mktemp)
        if jq --arg ts "$NOW" '.last_edit = $ts' "$STATE_FILE" > "$TMP" 2>/dev/null; then
            mv "$TMP" "$STATE_FILE"
        else
            rm -f "$TMP"
        fi
        ;;
    verification-feedback)
        # Act feedback loop: read the latest verification result and update state.json.
        # Called after verifier writes .sea/verification/phase-<N>.json.
        CURRENT_PHASE=$(jq -r '.current_phase // 0' "$STATE_FILE" 2>/dev/null || echo "0")
        VERIFY_FILE="${STATE_DIR}/verification/phase-${CURRENT_PHASE}.json"
        [ -f "$VERIFY_FILE" ] || exit 0

        VSTATUS=$(jq -r '.status // "unknown"' "$VERIFY_FILE" 2>/dev/null || echo "unknown")
        FINDINGS_COUNT=$(jq -r '.new_findings | length // 0' "$VERIFY_FILE" 2>/dev/null || echo "0")
        TDD_COMPLIANT=$(jq -r 'if .tdd_compliance.compliant == false then "false" else "true" end' "$VERIFY_FILE" 2>/dev/null || echo "true")

        TMP=$(mktemp)
        if jq \
            --arg ts "$NOW" \
            --arg vstatus "$VSTATUS" \
            --argjson findings "$FINDINGS_COUNT" \
            --argjson tdd "$TDD_COMPLIANT" \
            '.last_verification = {
                status: $vstatus,
                new_findings_count: $findings,
                tdd_compliant: $tdd,
                verified_at: $ts
            }' "$STATE_FILE" > "$TMP" 2>/dev/null; then
            mv "$TMP" "$STATE_FILE"
        else
            rm -f "$TMP"
        fi
        ;;
    *)
        echo "software-engineer-agents state-tracker: unknown action '${ACTION}'" >&2
        ;;
esac

exit 0
