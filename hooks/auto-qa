#!/usr/bin/env bash
#
# software-engineer-agents
# Copyright (C) 2026 demwick
# Licensed under the GNU Affero General Public License v3.0 or later.
# See LICENSE in the repository root for the full license text.
#
# Stop hook for software-engineer-agents.
# When .sea/.needs-verify exists, runs the project's test runner and
# reports failures back to Claude so it can auto-retry. Gives up after 2 retries.
#
# v2.0.0 schema: the marker and retry counter are separate files.
#   .sea/.needs-verify   — existence-only flag (content ignored).
#   .sea/.verify-attempts — JSON object {"attempts": N}, written atomically.
# v1 fixtures that wrote an integer into .needs-verify still work: if
# .verify-attempts is absent we fall back to reading the marker's content
# as an integer. This keeps the hook backward-compatible across the
# schema v1 → v2 migration while scripts/state-update.sh rolls state forward.

set -euo pipefail

# MAX_RETRIES rationale: two retries is the sweet spot for typical
# auto-QA failures (one fix attempt rarely finds the root cause, three
# turns the hook into a slow brute-force loop). Both the loop-protection
# give-up branch and the hard give-up branch read this constant so
# raising it in one place is enough to widen the retry window.
MAX_RETRIES=2

# TEST_TAIL_LINES rationale: tail -N of the test log is surfaced inside
# the Stop hook's block-decision reason so Claude gets actionable
# failure detail without reading the full log. 30 lines fits most stack
# traces (pytest tracebacks, Jest assertion output, Rust backtrace with
# `RUST_BACKTRACE=1`) while staying under the Stop hook decision
# payload budget. If real test suites routinely produce longer stacks,
# raise this in 10-line steps.
TEST_TAIL_LINES=30

STATE_DIR=".sea"
MARKER="${STATE_DIR}/.needs-verify"
ATTEMPTS_FILE="${STATE_DIR}/.verify-attempts"

# Read hook input (stdin JSON). Used to check stop_hook_active for loop protection.
INPUT=$(cat 2>/dev/null || echo "{}")

# No marker → nothing to verify, let Claude stop normally.
[ -f "$MARKER" ] || exit 0

# Require jq for safe JSON output. If missing, drop markers and exit cleanly.
if ! command -v jq >/dev/null 2>&1; then
    rm -f "$MARKER" "$ATTEMPTS_FILE"
    exit 0
fi

STOP_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false' 2>/dev/null || echo "false")

# Read retry counter: v2 .verify-attempts first, v1 .needs-verify content fallback.
ATTEMPTS=0
if [ -f "$ATTEMPTS_FILE" ]; then
    ATTEMPTS=$(jq -r '.attempts // 0' "$ATTEMPTS_FILE" 2>/dev/null || echo "0")
else
    # v1 fallback: marker content may be an integer retry count.
    MARKER_CONTENT=$(cat "$MARKER" 2>/dev/null || echo "")
    if printf '%s' "$MARKER_CONTENT" | grep -Eq '^[0-9]+$'; then
        ATTEMPTS="$MARKER_CONTENT"
    fi
fi
ATTEMPTS=${ATTEMPTS:-0}

# Loop-protection belt-and-suspenders: if the runtime is already looping AND we've
# already retried twice, give up and report the situation to the user.
if [ "$STOP_ACTIVE" = "true" ] && [ "$ATTEMPTS" -ge "$MAX_RETRIES" ]; then
    rm -f "$MARKER" "$ATTEMPTS_FILE"
    LAST_LOG="${STATE_DIR}/.last-verify.log"
    jq -cn --arg log "$LAST_LOG" --arg max "$MAX_RETRIES" \
        '{decision: "block", reason: ("Auto-QA loop-protection tripped after " + $max + " retries — tests are still failing. Review " + $log + " and report the situation to the user. Do not keep retrying.")}'
    exit 0
fi

# Detect test runner via shared helper script.
TEST_CMD=""
DETECT_SCRIPT="${CLAUDE_PLUGIN_ROOT:-}/scripts/detect-test.sh"
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$DETECT_SCRIPT" ]; then
    TEST_CMD=$(bash "$DETECT_SCRIPT" . 2>/dev/null || true)
fi

# No detectable test runner → auto-pass, clear marker + counter.
if [ -z "$TEST_CMD" ]; then
    rm -f "$MARKER" "$ATTEMPTS_FILE"
    exit 0
fi

# Run the tests, capturing output.
TEST_LOG="${STATE_DIR}/.last-verify.log"
mkdir -p "$STATE_DIR"

if sh -c "$TEST_CMD" > "$TEST_LOG" 2>&1; then
    # Tests passed. Run host-compat sanity check before letting Claude stop —
    # pyproject.toml requires-python can mismatch host Python silently while
    # pytest runs fine in a managed venv. Same for other packaging traps.
    COMPAT_SCRIPT="${CLAUDE_PLUGIN_ROOT:-}/scripts/check-host-compat.sh"
    if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$COMPAT_SCRIPT" ]; then
        COMPAT_OUT=$(bash "$COMPAT_SCRIPT" . 2>/dev/null) && COMPAT_EXIT=0 || COMPAT_EXIT=$?
        if [ "$COMPAT_EXIT" = "10" ] && [ -n "$COMPAT_OUT" ]; then
            # Append to log so /sea-status and humans can see it later.
            printf '\n\n=== host-compat warning ===\n%s\n' "$COMPAT_OUT" >> "$TEST_LOG"
            # Return a block so Claude fixes it now rather than shipping broken packaging.
            rm -f "$MARKER" "$ATTEMPTS_FILE"
            jq -cn --arg msg "$COMPAT_OUT" \
                '{decision: "block", reason: ("Tests passed but host-compat check failed: " + $msg + " Fix the packaging metadata and re-run tests. Do not skip — this blocks pip install on the user host.")}'
            exit 0
        fi
    fi
    # Pass → clear marker + counter, let Claude stop.
    rm -f "$MARKER" "$ATTEMPTS_FILE"
    exit 0
fi

# Tests failed.
NEXT=$((ATTEMPTS + 1))

if [ "$NEXT" -gt "$MAX_RETRIES" ]; then
    rm -f "$MARKER" "$ATTEMPTS_FILE"
    jq -cn \
        --arg log "$TEST_LOG" --arg max "$MAX_RETRIES" \
        '{decision: "block", reason: ("Auto-QA gave up after " + $max + " retries — tests are still failing. Review " + $log + " and report the situation to the user. Do not keep retrying.")}'
    exit 0
fi

# Record the retry attempt atomically (temp file + mv) in .verify-attempts.
TMP_ATTEMPTS=$(mktemp)
jq -n --argjson n "$NEXT" '{attempts: $n}' > "$TMP_ATTEMPTS"
mv "$TMP_ATTEMPTS" "$ATTEMPTS_FILE"
TEST_TAIL=$(tail -"$TEST_TAIL_LINES" "$TEST_LOG" 2>/dev/null || echo "")

jq -cn \
    --arg cmd "$TEST_CMD" \
    --arg tail "$TEST_TAIL" \
    --arg n "$NEXT" \
    --arg max "$MAX_RETRIES" \
    '{
        decision: "block",
        reason: ("Auto-QA: tests failed (attempt " + $n + "/" + $max + "). Test command: " + $cmd + "\n\nLast output:\n" + $tail + "\n\nRead the full log at .sea/.last-verify.log, diagnose the root cause, and fix the failing tests. The Stop hook will re-verify automatically.")
    }'
exit 0
